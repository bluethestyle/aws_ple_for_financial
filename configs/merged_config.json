      "derive": {
        "method": "nba_group_check",
        "source_col": "nba_label",
        "indices": [
          2,
          5,
          6,
          7,
          11,
          19
        ]
      }
    },
    {
      "name": "will_acquire_lending",
      "type": "binary",
      "loss": "focal",
      "loss_params": {
        "alpha": 0.9,
        "gamma": 2.0
      },
      "loss_weight": 1.5,
      "label_col": "label_acquire_lending",
      "description": "Any of nba_label indices [13,15] (mortgage, loans)",
      "derive": {
        "method": "nba_group_check",
        "source_col": "nba_label",
        "indices": [
          13,
          15
        ]
      }
    },
    {
      "name": "will_acquire_payments",
      "type": "binary",
      "loss": "focal",
      "loss_params": {
        "alpha": 0.85,
        "gamma": 2.0
      },
      "loss_weight": 1.2,
      "label_col": "label_acquire_payments",
      "description": "Any of nba_label indices [4,17,20,22,23] (credit_card, direct/auto debit, payroll)",
      "derive": {
        "method": "nba_group_check",
        "source_col": "nba_label",
        "indices": [
          4,
          17,
          20,
          22,
          23
        ]
      }
