{
  "task_name": "santander_ple",
  "adapter": "santander",
  "feature_groups_file": "configs/santander/feature_groups.yaml",
  "tasks": [
    {
      "name": "churn_signal",
      "type": "binary",
      "loss": "focal",
      "loss_params": {
        "alpha": 0.85,
        "gamma": 2.0
      },
      "loss_weight": 2.0,
      "label_col": "churn_signal",
      "description": "Churn signal: product count < prior avg x 0.7 (5.1% positive)"
    },
    {
      "name": "product_stability",
      "type": "regression",
      "loss": "huber",
      "loss_weight": 1.5,
      "label_col": "product_stability",
      "nullable": true,
      "description": "Product holding stability (1-CV), 0-1, avg 0.92, nullable"
    },
    {
      "name": "nba_primary",
      "type": "multiclass",
      "loss": "ce",
      "loss_weight": 2.0,
      "label_col": "label_nba_primary",
      "num_classes": 7,
      "topk_k": [
        1,
        3
      ],
      "description": "Next best action — product group to recommend (0=no_nba, 1=savings_guarantee, 2=checking_accounts, 3=deposits, 4=investments, 5=credit_loans, 6=debits)",
      "derive": {
        "method": "list_first_group",
        "source_col": "nba_label",
        "filter_col": "has_nba",
        "default": 0
      }
    },
    {
      "name": "cross_sell_count",
      "type": "regression",
      "loss": "huber",
      "loss_weight": 1.0,
      "label_col": "label_cross_sell_count",
      "description": "Number of products in nba_label list (0-24)",
      "derive": {
        "method": "len_of_list",
        "source_col": "nba_label"
      }
    },
    {
      "name": "will_acquire_deposits",
      "type": "binary",
      "loss": "focal",
      "loss_params": {
        "alpha": 0.95,
        "gamma": 2.0
      },
      "loss_weight": 1.5,
      "label_col": "label_acquire_deposits",
      "description": "Any of nba_label indices [8,9,10] (short/medium/long deposit)",
      "derive": {
        "method": "nba_group_check",
        "source_col": "nba_label",
        "indices": [
          8,
          9,
          10
        ]
      }
    },
    {
      "name": "will_acquire_investments",
      "type": "binary",
      "loss": "focal",
      "loss_params": {
        "alpha": 0.9,
        "gamma": 2.0
      },
      "loss_weight": 1.5,
      "label_col": "label_acquire_investments",
      "description": "Any of nba_label indices [12,18] (funds, securities)",
      "derive": {
        "method": "nba_group_check",
        "source_col": "nba_label",
        "indices": [
          12,
          18
        ]
      }
    },
    {
      "name": "will_acquire_accounts",
      "type": "binary",
      "loss": "focal",
      "loss_params": {
        "alpha": 0.85,
        "gamma": 2.0
      },
      "loss_weight": 1.2,
      "label_col": "label_acquire_accounts",
      "description": "Any of nba_label indices [2,5,6,7,11,19] (checking, junior, particular, e_account, home)",
      "derive": {
        "method": "nba_group_check",
        "source_col": "nba_label",
        "indices": [
          2,
          5,
          6,
          7,
          11,
          19
        ]
      }
    },
    {
      "name": "will_acquire_lending",
      "type": "binary",
      "loss": "focal",
      "loss_params": {
        "alpha": 0.9,
        "gamma": 2.0
      },
      "loss_weight": 1.5,
      "label_col": "label_acquire_lending",
      "description": "Any of nba_label indices [13,15] (mortgage, loans)",
      "derive": {
        "method": "nba_group_check",
        "source_col": "nba_label",
        "indices": [
          13,
          15
        ]
      }
    },
    {
      "name": "will_acquire_payments",
      "type": "binary",
      "loss": "focal",
      "loss_params": {
        "alpha": 0.85,
        "gamma": 2.0
      },
      "loss_weight": 1.2,
      "label_col": "label_acquire_payments",
      "description": "Any of nba_label indices [4,17,20,22,23] (credit_card, direct/auto debit, payroll)",
      "derive": {
        "method": "nba_group_check",
        "source_col": "nba_label",
        "indices": [
          4,
          17,
          20,
          22,
          23
        ]
      }
    },
    {
      "name": "next_mcc",
      "type": "multiclass",
      "loss": "ce",
      "loss_weight": 1.2,
      "label_col": "label_next_mcc",
      "num_classes": 50,
      "topk_k": [
        1,
        5,
        10
      ],
      "description": "Predict next MCC category from txn sequence (top-50 MCCs)",
      "derive": {
        "method": "sequence_next",
        "source_seq": "txn_mcc_seq",
        "top_k": 50
      }
    },
    {
      "name": "mcc_diversity_trend",
      "type": "regression",
      "loss": "huber",
      "loss_weight": 0.8,
      "label_col": "label_mcc_diversity_trend",
      "description": "MCC diversity trend: change in unique MCC count over recent windows",
      "derive": {
        "method": "sequence_diversity_trend",
        "source_seq": "txn_mcc_seq",
        "window_sizes": [
          10,
          30
        ]
      }
    },
    {
      "name": "top_mcc_shift",
      "type": "binary",
      "loss": "focal",
      "loss_params": {
        "alpha": 0.7,
        "gamma": 2.0
      },
      "loss_weight": 1.0,
      "label_col": "label_top_mcc_shift",
      "description": "Did the customer's top MCC category change recently?",
      "derive": {
        "method": "sequence_mode_shift",
        "source_seq": "txn_mcc_seq",
        "window_sizes": [
          15,
          30
        ]
      }
    }
  ],
  "labels": {
    "churn_signal": {
      "source": "churn_signal",
      "type": "direct"
    },
    "product_stability": {
      "source": "product_stability",
      "type": "direct"
    },
    "label_nba_primary": {
      "source": "nba_label",
      "type": "list_first_group",
      "default": 0,
      "group_map": {
        "1": [
          0,
          1
        ],
        "2": [
          2,
          3,
          4,
          5,
          6,
          7,
          19,
          20
        ],
        "3": [
          8,
          9,
          10,
          11
        ],
        "4": [
          12,
          13,
          14
        ],
        "5": [
          15,
          16,
          17,
          18
        ],
        "6": [
          21,
          22,
          23
        ]
      }
    },
    "label_cross_sell_count": {
      "source": "nba_label",
      "type": "list_length"
    },
    "label_acquire_deposits": {
      "source": "nba_label",
      "type": "list_intersect",
      "indices": [
        8,
        9,
        10
      ]
    },
    "label_acquire_investments": {
      "source": "nba_label",
      "type": "list_intersect",
      "indices": [
        12,
        18
      ]
    },
    "label_acquire_accounts": {
      "source": "nba_label",
      "type": "list_intersect",
      "indices": [
        2,
        5,
        6,
        7,
        11,
        19
      ]
    },
    "label_acquire_lending": {
      "source": "nba_label",
      "type": "list_intersect",
      "indices": [
        13,
        15
      ]
    },
    "label_acquire_payments": {
      "source": "nba_label",
      "type": "list_intersect",
      "indices": [
        4,
        17,
        20,
        22,
        23
      ]
    },
    "label_next_mcc": {
      "source": "txn_mcc_seq",
      "type": "sequence_last",
      "top_k": 50,
      "default": -1
    },
    "label_mcc_diversity_trend": {
      "source": "txn_mcc_seq",
      "type": "sequence_diversity_trend"
    },
    "label_top_mcc_shift": {
      "source": "txn_mcc_seq",
      "type": "sequence_mode_shift"
    }
  },
  "sequences": {
    "txn_sequences": {
      "mode": "time_based",
      "window_days": 90,
      "stride_days": 30,
      "max_len": 200,
      "timestamp_col": "txn_date",
      "columns": {
        "txn_amount_seq": {
          "feat_dim": 1,
          "dtype": "float",
          "description": "Transaction amount sequence (variable-length, up to 200)"
        },
        "txn_mcc_seq": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "MCC code sequence (variable-length, up to 200)"
        },
        "txn_hour_seq": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Transaction hour sequence (0-23, variable-length)"
        },
        "txn_date_seq": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Transaction date (YYYYMMDD int, for time-based windowing)"
        }
      }
    },
    "product_sequences": {
      "mode": "count_based",
      "max_len": 16,
      "truncate_last": 1,
      "columns": {
        "seq_saving": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Savings account holding (0/1/-1)"
        },
        "seq_guarantee": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Guarantee holding (0/1/-1)"
        },
        "seq_checking": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Checking account holding (0/1/-1)"
        },
        "seq_derivados": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Derivados holding (0/1/-1)"
        },
        "seq_payroll_acct": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Payroll account holding (0/1/-1)"
        },
        "seq_junior_acct": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Junior account holding (0/1/-1)"
        },
        "seq_particular_acct": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Particular account holding (0/1/-1)"
        },
        "seq_particular_plus": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Particular plus holding (0/1/-1)"
        },
        "seq_short_deposit": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Short deposit holding (0/1/-1)"
        },
        "seq_medium_deposit": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Medium deposit holding (0/1/-1)"
        },
        "seq_long_deposit": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Long deposit holding (0/1/-1)"
        },
        "seq_e_account": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "E-account holding (0/1/-1)"
        },
        "seq_funds": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Funds holding (0/1/-1)"
        },
        "seq_mortgage": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Mortgage holding (0/1/-1)"
        },
        "seq_pension_plan": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Pension plan holding (0/1/-1)"
        },
        "seq_loans": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Loans holding (0/1/-1)"
        },
        "seq_taxes": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Taxes holding (0/1/-1)"
        },
        "seq_credit_card": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Credit card holding (0/1/-1)"
        },
        "seq_securities": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Securities holding (0/1/-1)"
        },
        "seq_home_acct": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Home account holding (0/1/-1)"
        },
        "seq_payroll": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Payroll service holding (0/1/-1)"
        },
        "seq_pension_deposit": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Pension deposit holding (0/1/-1)"
        },
        "seq_direct_debit": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Direct debit holding (0/1/-1)"
        },
        "seq_auto_debit": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Auto debit holding (0/1/-1)"
        },
        "seq_num_products": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Total products held per month (0-15)"
        },
        "seq_acquisitions": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Monthly new acquisitions (len 1-16)"
        },
        "seq_churns": {
          "feat_dim": 1,
          "dtype": "int",
          "description": "Monthly churns (len 1-16)"
        }
      }
    }
  },
  "task_groups": [
    {
      "name": "engagement",
      "description": "고객이 반응하는가",
      "tasks": [
        "next_mcc",
        "top_mcc_shift"
      ],
      "adatt_intra_strength": 0.8,
      "adatt_inter_strength": 0.3
    },
    {
      "name": "lifecycle",
      "description": "고객이 어디에 있는가",
      "tasks": [
        "churn_signal",
        "product_stability"
      ],
      "adatt_intra_strength": 0.7,
      "adatt_inter_strength": 0.3
    },
    {
      "name": "value",
      "description": "언제/어디서 가치를 만드는가",
      "tasks": [
        "mcc_diversity_trend"
      ],
      "adatt_intra_strength": 0.6,
      "adatt_inter_strength": 0.3
    },
    {
      "name": "consumption",
      "description": "무엇을 소비하는가",
      "tasks": [
        "nba_primary",
        "cross_sell_count",
        "will_acquire_deposits",
        "will_acquire_investments",
        "will_acquire_accounts",
        "will_acquire_lending",
        "will_acquire_payments"
      ],
      "adatt_intra_strength": 0.7,
      "adatt_inter_strength": 0.3
    }
  ],
  "adatt": {
    "transfer_lambda": 0.1,
    "temperature": 1.0,
    "warmup_epochs": 3,
    "freeze_epoch": 8,
    "grad_interval": 10,
    "inter_group_strength": 0.3
  },
  "grad_surgery": {
    "enabled": false,
    "conflict_threshold": 0.0,
    "warmup_epochs": 3,
    "grad_interval": 10,
    "ema_decay": 0.9,
    "log_interval": 1,
    "task_type_groups": {
      "binary": [
        "churn_signal",
        "will_acquire_deposits",
        "will_acquire_investments",
        "will_acquire_accounts",
        "will_acquire_lending",
        "will_acquire_payments",
        "top_mcc_shift"
      ],
      "multiclass": [
        "nba_primary",
        "next_mcc"
      ],
      "regression": [
        "product_stability",
        "cross_sell_count",
        "mcc_diversity_trend"
      ]
    }
  },
  "task_relationships": [
    {
      "source": "churn_signal",
      "target": "product_stability",
      "type": "causal",
      "transfer_method": "output_concat",
      "description": "이탈 → 상품 안정성"
    },
    {
      "source": "next_mcc",
      "target": "nba_primary",
      "type": "sequential",
      "transfer_method": "hidden_concat",
      "description": "다음 업종 → 다음 상품 (feature sharing)"
    }
  ],
  "logit_transfer_strength": 0.5,
  "scoring": {
    "method": "fd_tvs",
    "weights": {
      "nba_primary": 0.2,
      "cross_sell_count": 0.1,
      "churn_signal": 0.15,
      "product_stability": 0.1,
      "top_mcc_shift": 0.05,
      "next_mcc": 0.05,
      "mcc_diversity_trend": 0.05,
      "will_acquire_deposits": 0.08,
      "will_acquire_investments": 0.07,
      "will_acquire_accounts": 0.05,
      "will_acquire_lending": 0.05,
      "will_acquire_payments": 0.05
    },
    "dna_modifier": {
      "segment_weights": {
        "01-TOP": 1.3,
        "02-PARTICULARES": 1.0,
        "03-UNIVERSITARIO": 0.8,
        "UNKNOWN": 0.7
      }
    },
    "fatigue": {
      "decay_rate": 0.85,
      "max_messages_7d": 5
    },
    "risk_penalty": {
      "max_churn_prob": 0.6,
      "min_score": 0.05
    },
    "segment_task_weights": {
      "01-TOP": {
        "will_acquire_investments": 1.4,
        "product_stability": 1.3,
        "cross_sell_count": 1.2
      },
      "02-PARTICULARES": {
        "will_acquire_deposits": 1.3,
        "will_acquire_payments": 1.2,
        "churn_signal": 1.2
      },
      "03-UNIVERSITARIO": {
        "will_acquire_accounts": 1.4,
        "will_acquire_payments": 1.3,
        "top_mcc_shift": 1.2
      },
      "UNKNOWN": {
        "churn_signal": 1.4,
        "will_acquire_deposits": 1.2
      }
    },
    "dynamic_weight_rules": [
      {
        "feature": "churn_prob",
        "threshold": 0.5,
        "task": "churn_signal",
        "boost": 1.4
      },
      {
        "feature": "income",
        "threshold": 200000,
        "task": "will_acquire_investments",
        "boost": 1.3
      },
      {
        "feature": "product_diversity",
        "threshold": 0.3,
        "task": "will_acquire_deposits",
        "boost": 1.3
      },
      {
        "feature": "engagement_score",
        "threshold": 0.7,
        "task": "will_acquire_investments",
        "boost": 1.2
      }
    ]
  },
  "constraints": {
    "filters": [
      {
        "type": "fatigue",
        "max_messages_7d": 5
      },
      {
        "type": "eligibility",
        "min_score": 0.05,
        "max_churn_prob": 0.6
      },
      {
        "type": "owned_product",
        "check_column_prefix": "prod_"
      }
    ],
    "product_eligibility": {
      "standard": {
        "min_tenure_months": 3
      },
      "growth": {
        "min_tenure_months": 6
      },
      "premium": {
        "min_tenure_months": 12
      }
    },
    "top_k": {
      "k": 5,
      "diversity_method": "mmr",
      "diversity_lambda": 0.5
    }
  },
  "cold_start": {
    "seq_col": "txn_amount_seq",
    "min_txn_count": 3,
    "zero_features_prefix": [
      "hmm_states",
      "mamba_temporal",
      "tda_local"
    ],
    "keep_features_prefix": [
      "prod_",
      "synth_",
      "tda_global",
      "gmm_",
      "graph_"
    ]
  },
  "data": {
    "source": "data/benchmark/benchmark_v12.parquet",
    "s3_path": "s3://YOUR_S3_BUCKET/data/santander/",
    "id_col": "customer_id",
    "backend": [
      "cudf",
      "duckdb",
      "pandas"
    ],
    "format": "parquet",
    "total_rows": 1000000,
    "train_split": 0.7,
    "val_split": 0.15,
    "temporal_split": {
      "enabled": true,
      "date_col": "snapshot_date",
      "gap_days": 30,
      "train_ratio": 0.7,
      "val_ratio": 0.15
    },
    "split_strategy": {
      "state_tasks": {
        "tasks": [
          "churn_signal",
          "product_stability"
        ],
        "val_method": "random"
      },
      "future_tasks": {
        "tasks": [
          "nba_primary",
          "will_acquire_deposits",
          "will_acquire_investments",
          "will_acquire_accounts",
          "will_acquire_lending",
          "will_acquire_payments",
          "cross_sell_count"
        ],
        "val_method": "temporal_latest"
      },
      "sequence_tasks": {
        "tasks": [
          "next_mcc",
          "mcc_diversity_trend",
          "top_mcc_shift"
        ],
        "val_method": "temporal_latest"
      }
    },
    "preprocessing": {
      "fit_subsample_limit": 10000,
      "income": {
        "null_indicator": 0,
        "null_rate": 0.254,
        "strategy": "median"
      },
      "tenure_months": {
        "sentinel": -999999,
        "strategy": "clip_and_flag",
        "clip_min": 0,
        "clip_max": 256,
        "flag_col": "tenure_unknown"
      },
      "leakage_prevention": {
        "recompute_prod_from_seq": true,
        "validate_after_split": true
      }
    }
  },
  "features": {
    "id_cols": [
      "customer_id"
    ],
    "meta_cols": [
      "snapshot_date"
    ],
    "input_dim": 512,
    "normalizer": {
      "categorical_id_suffixes": [
        "_cluster_id",
        "_state_id",
        "_segment_id",
        "_group_id"
      ],
      "categorical_id_prefixes": [
        "txn_lag_mcc_",
        "txn_lag_hour_"
      ],
      "probability_prefixes": [
        "gmm_clustering_cluster_prob_",
        "model_derived_gmm_prob_"
      ]
    },
    "categorical": [
      {
        "name": "gender",
        "cardinality": 2,
        "embedding_dim": 4
      },
      {
        "name": "segment",
        "cardinality": 4,
        "embedding_dim": 4
      },
      {
        "name": "country",
        "cardinality": 118,
        "embedding_dim": 16
      },
      {
        "name": "channel",
        "cardinality": 163,
        "embedding_dim": 16
      },
      {
        "name": "age_group",
        "cardinality": 5,
        "embedding_dim": 4
      },
      {
        "name": "income_group",
        "cardinality": 5,
        "embedding_dim": 4
      }
