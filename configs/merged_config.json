{
  "model": {
    "architecture": "ple",
    "expert_basket": {
      "shared": [
        "deepfm",
        "temporal_ensemble",
        "hgcn",
        "perslay",
        "causal",
        "lightgcn",
        "optimal_transport"
      ],
      "task": [
        "mlp"
      ]
    },
    "expert_config": {
      "deepfm": {
        "embedding_dim": 16,
        "hidden_dims": [
          256,
          128,
          64
        ],
        "dropout": 0.2,
        "field_dims": "auto"
      },
      "temporal_ensemble": {
        "mamba_d_model": 64,
        "mamba_n_layers": 2,
        "transformer_n_heads": 4,
        "transformer_n_layers": 2,
        "lnn_hidden_dim": 64
      },
      "hgcn": {
        "hyperbolic_dim": 20,
        "product_dim": 24,
        "refine_hidden": 128
      },
      "perslay": {
        "phi_hidden_dim": 64,
        "rho_hidden_dim": 64
      },
      "causal": {
        "dag_hidden_dims": [
          128,
          64
        ],
        "lambda_dag": 0.01
      },
      "lightgcn": {
        "embedding_dim": 64,
        "n_layers": 3
      },
      "optimal_transport": {
        "hidden_dims": [
          128,
          64
        ],
        "sinkhorn_iterations": 10
      },
      "mlp": {
        "hidden_dims": [
          128,
          64
        ],
        "dropout": 0.2
      }
    },
    "cgc": {
      "dim_normalize": true
    },
    "ple": {
      "num_layers": 3,
      "extraction_dim": 64,
      "num_shared_experts": 7,
      "num_task_experts": 1
    },
    "evidential": {
      "enabled": true,
      "kl_lambda": 0.01,
      "annealing_epochs": 10
    },
    "sae": {
      "enabled": true,
      "weight": 0.01,
      "expansion_factor": 4,
      "l1_lambda": 0.001
    },
    "loss_weighting": {
      "strategy": "uncertainty"
    },
    "group_task_expert": {
      "enabled": true,
      "group_hidden": 128,
      "group_output": 64,
      "cluster_embed_dim": 32
    },
    "task_tower": {
      "default_dims": [
        64,
        32
      ],
      "dropout": 0.1
    },
    "hmm_group_mode_map": {
      "engagement": "behavior",
      "lifecycle": "lifecycle",
      "value": "journey",
      "consumption": "journey"
    },
    "multidisciplinary_routing": {
      "engagement": [
        0,
        1,
        2,
        3,
        4,
        5
      ],
      "lifecycle": [
        6,
        7,
        8,
        9,
        10,
        11
      ],
      "value": [
        12,
        13,
        14,
        15,
        16,
        17
      ],
      "consumption": [
        18,
        19,
        20,
        21,
        22,
        23
      ]
    }
  },
  "adatt": {
    "transfer_lambda": 0.1,
    "temperature": 1.0,
    "warmup_epochs": 3,
    "freeze_epoch": 8,
    "grad_interval": 10,
    "inter_group_strength": 0.3
  },
  "grad_surgery": {
    "enabled": false,
    "conflict_threshold": 0.0,
    "warmup_epochs": 3,
    "grad_interval": 10,
    "ema_decay": 0.9,
    "log_interval": 1,
    "task_type_groups": {
      "binary": [
        "churn_signal",
        "will_acquire_deposits",
        "will_acquire_investments",
        "will_acquire_accounts",
        "will_acquire_lending",
        "will_acquire_payments",
        "top_mcc_shift"
      ],
      "multiclass": [
        "nba_primary",
        "segment_prediction",
        "next_mcc"
      ],
      "regression": [
        "product_stability",
        "cross_sell_count",
        "mcc_diversity_trend"
      ]
    }
  },
  "training": {
    "experiment_name": "santander_ple",
    "batch_size": 2048,
    "epochs": 50,
    "learning_rate": 0.0005,
    "weight_decay": 0.01,
    "gradient_clip_norm": 5.0,
    "seed": 42,
    "phase1": {
      "epochs": 15,
      "description": "shared expert learning"
    },
    "phase2": {
      "epochs": 8,
      "freeze_shared": true,
      "description": "task head fine-tuning"
    },
    "early_stopping": {
      "patience": 7,
      "metric": "val_loss"
    },
    "scheduler": {
      "type": "cosine",
      "warmup_epochs": 3
    },
    "amp": {
      "enabled": true,
      "grad_scaler_init_scale": 1024.0,
      "grad_scaler_growth_factor": 2.0,
      "grad_scaler_backoff_factor": 0.5,
      "grad_scaler_growth_interval": 2000,
      "grad_scaler_max_scale": 4096.0
    }
  },
  "distillation": {
    "temperature": 1.0,
    "alpha": 0.3,
    "lgbm": {
      "num_leaves": 127,
      "learning_rate": 0.05,
      "n_estimators": 500,
      "min_child_samples": 50,
      "subsample": 0.8,
      "colsample_bytree": 0.8
    },
    "task_lgbm_overrides": {
      "cross_sell_count": {
        "objective": "huber",
        "alpha": 0.9
      },
      "mcc_diversity_trend": {
        "objective": "huber",
        "alpha": 0.9
      },
      "product_stability": {
        "objective": "huber",
        "alpha": 0.9
      }
    },
    "teacher_threshold": {
      "binary_min_auc": 0.6,
      "multiclass_min_f1_ratio": 2.0,
      "regression_min_r2": 0.05,
      "floor_binary_auc": 0.52,
      "floor_multiclass_f1_ratio": 1.0,
      "floor_regression_r2": 0.01
    },
    "calibration": {
      "enabled": true,
      "method": "platt",
      "tasks": [
        "churn_signal",
        "product_stability",
        "cross_sell_count"
      ]
    },
    "fidelity": {
      "binary": {
        "max_auc_gap": 0.05,
        "min_agreement": 0.85,
        "max_jsd": 0.1,
        "min_ranking_corr": 0.9,
        "max_calibration_gap": 0.05
      },
      "multiclass": {
        "min_agreement": 0.7,
        "max_jsd": 0.1,
        "max_f1_macro_gap": 0.1
      },
      "regression": {
        "min_ranking_corr": 0.9,
        "min_quartile_agreement": 0.7,
        "max_mae_gap": 0.05,
        "max_rmse_gap": 0.1
      }
    },
    "feature_selection": {
      "method": "lgbm_gain",
      "top_k": null,
      "cumulative_threshold": 0.95
    },
    "drift_monitoring": {
      "enabled": true,
      "max_psi": 0.2,
      "max_jsd": 0.1,
      "max_auc_shift": 0.05,
      "max_prediction_shift": 0.1,
      "min_rank_correlation": 0.95,
      "baseline_path": "outputs/distillation_baseline/"
    },
    "feature_drift": {
      "enabled": true,
      "baseline_path": "outputs/distillation_baseline/feature_baseline.json",
      "psi_threshold_warning": 0.1,
      "psi_threshold_critical": 0.25
    }
  },
  "monitoring": {
    "fairness": {
      "thresholds": {
        "di_lower": 0.8,
        "di_upper": 1.25,
        "spd_max": 0.1,
        "eod_max": 0.1
      },
      "auto_incident": true
    },
    "drift": {
      "psi_warning": 0.1,
      "psi_critical": 0.25,
      "n_bins": 10
    },
    "incidents": {
      "severity_thresholds": {
        "critical": [
          "kill_switch_activation",
          "di_below_0.6",
          "security_breach"
        ],
        "major": [
          "di_below_0.8",
          "herding_critical",
          "model_rollback",
          "consecutive_drift_retrain"
        ],
        "minor": [
          "drift_warning",
          "quality_drop",
          "herding_high",
          "single_feature_critical"
        ]
      }
    },
    "governance_report": {
      "enabled": true,
      "frequency": "weekly"
    }
  },
  "evaluation": {
    "binary": {
      "metrics": [
        "auc_roc",
        "auc_pr",
        "f1",
        "precision",
        "recall",
        "accuracy",
        "log_loss"
      ],
      "primary": "auc_roc"
    },
    "multiclass": {
      "metrics": [
        "accuracy",
        "f1_macro",
        "f1_weighted",
        "top_k_accuracy"
      ],
      "primary": "f1_macro"
    },
    "regression": {
      "metrics": [
        "rmse",
        "mae",
        "r2",
        "mape"
      ],
      "primary": "rmse"
    }
  },
  "analysis": {
    "enabled": true,
    "ig_steps": 20,
    "integrated_gradients": {
      "n_steps": 50,
      "baseline": "zeros",
      "max_batches": 50
    },
    "expert_redundancy": {
      "enabled": true,
      "max_batches": 20,
      "n_components": 10,
      "min_samples": 256
    },
    "xai_quality": {
      "enabled": true
    },
    "model_card": {
      "enabled": true
    }
  },
  "llm_provider": {
    "backend": "bedrock",
    "bedrock": {
      "region": "ap-northeast-2",
      "models": {
        "reason_generation": {
          "model_id": "global.anthropic.claude-sonnet-4-6",
          "max_tokens": 500,
          "temperature": 0.3
        },
        "reason_critique": {
          "model_id": "global.anthropic.claude-sonnet-4-6",
          "max_tokens": 500,
          "temperature": 0.2
        },
        "factuality_check": {
          "model_id": "global.anthropic.claude-haiku-4-5-20251001-v1:0",
          "max_tokens": 300,
          "temperature": 0.0
        },
        "agent_dialog": {
          "model_id": "global.anthropic.claude-sonnet-4-6",
          "max_tokens": 2000,
          "temperature": 0.1
        },
        "agent_consensus": {
          "model_id": "global.anthropic.claude-sonnet-4-6",
          "max_tokens": 2000,
          "temperature": 0.1
        }
      },
      "default": {
        "model_id": "global.anthropic.claude-haiku-4-5-20251001-v1:0",
        "max_tokens": 500,
        "temperature": 0.2
      }
    }
  },
  "reason": {
    "fact_extractor": {
      "config_path": "configs/financial/fact_extraction.yaml"
    },
    "template_engine": {
      "item_name_map": {
        "churn_signal": "고객 유지 프로그램",
        "will_acquire_deposits": "예적금 상품",
        "will_acquire_investments": "투자 상품",
        "will_acquire_accounts": "입출금 계좌",
        "will_acquire_lending": "대출 상품",
        "will_acquire_payments": "결제 서비스",
        "top_mcc_shift": "맞춤 소비 혜택",
        "product_stability": "자산 안정화 서비스",
        "nba_primary": "추천 금융 상품",
        "cross_sell_count": "교차판매 상품",
        "segment_prediction": "고객 맞춤 서비스",
        "next_mcc": "소비 카테고리 추천",
        "mcc_diversity_trend": "소비 다양성 혜택"
      },
      "feature_category_map": {
        "synth_monthly_spend": "spending",
        "synth_monthly_txns": "transaction",
        "synth_frequency": "transaction",
        "synth_recency_days": "engagement",
        "synth_stability": "stability",
        "synth_monetary": "spending",
        "synth_avg_amount": "spending",
        "synth_unique_mcc": "consumption",
        "synth_unique_merchants": "consumption",
        "hmm_states_journey": "lifecycle",
        "hmm_states_lifecycle": "lifecycle",
        "hmm_states_behavior": "behavior",
        "gmm_clustering": "segment",
        "model_derived_bandit": "recommendation",
        "model_derived_lnn": "behavior",
        "model_derived_gmm": "segment",
        "income": "demographics",
        "age": "demographics",
        "is_active": "engagement",
        "total_churns": "engagement",
        "label_engagement_score": "engagement",
        "label_income_tier": "demographics",
        "label_tenure_stage": "lifecycle",
        "label_segment": "segment",
        "prod_": "product_holding",
        "seq_": "product_holding",
        "tda_": "topology",
        "graph_": "topology",
        "economics_pih": "income_stability"
      },
      "template_pool": {
        "spending": [
          "고객님의 소비 패턴을 분석한 결과, {item_name}이(가) 적합합니다.",
