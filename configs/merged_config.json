  "dataset": {
    "name": "santander",
    "description": "Santander Customer Transactions benchmark. 941,132 users, 89 raw columns, 13 tasks, 7 shared experts. Pre-aggregated user-level synthetic dataset with product holdings, transaction sequences, and demographic attributes.\n",
    "total_rows": 941132,
    "feature_groups_file": "configs/santander/feature_groups.yaml"
