        ],
        "income_stability": [
          "소득 안정성을 고려하여 적합한 {item_name}을(를) 안내드립니다.",
          "장기적인 소득 흐름에 맞는 {item_name}입니다."
        ]
      },
      "task_frames": {
        "churn_signal": {
          "positive": "고객님의 소중한 거래 관계를 유지하고자 합니다. {reason}",
          "negative": "항상 함께해 주셔서 감사합니다. {reason}"
        },
        "will_acquire_deposits": {
          "positive": "자산 증식에 도움이 될 수 있습니다. {reason}"
        },
        "will_acquire_investments": {
          "positive": "고객님의 재무 목표에 부합할 수 있습니다. {reason}"
        },
        "will_acquire_accounts": {
          "positive": "효율적인 자금 관리에 도움이 됩니다. {reason}"
        },
        "will_acquire_lending": {
          "positive": "현재 자금 수요에 적합한 상품입니다. {reason}"
        },
        "will_acquire_payments": {
          "positive": "간편한 결제 환경을 제공합니다. {reason}"
        },
        "top_mcc_shift": {
          "positive": "소비 패턴의 변화에 맞춘 혜택입니다. {reason}"
        },
        "product_stability": {
          "positive": "안정적인 자산 관리를 위해 추천드립니다. {reason}"
        },
        "nba_primary": {
          "positive": "고객님께 가장 적합한 상품입니다. {reason}"
        },
        "cross_sell_count": {
          "positive": "포트폴리오 확장에 도움이 될 수 있습니다. {reason}"
        },
        "segment_prediction": {
          "positive": "고객님의 금융 니즈에 맞춤 설계된 서비스입니다. {reason}"
        },
        "next_mcc": {
          "positive": "소비 패턴 분석을 기반으로 추천드립니다. {reason}"
        },
        "mcc_diversity_trend": {
          "positive": "다양한 소비 경험을 위한 혜택입니다. {reason}"
        }
      }
    },
    "async_orchestrator": {
      "sqs_queue_url": "",
      "dynamo_table": "reason_cache"
    },
    "self_checker": {
      "enable_llm_check": true,
      "pii_check": true,
      "hallucination_check": true,
      "regulatory_check": true
    }
  },
  "serving_prep": {
    "enabled": false,
    "context_store": {
      "backend": "auto",
      "embedding_source": "feature_pipeline",
      "store_path": "s3://aiops-ple-financial/context_store/"
    },
    "reason_generation": {
      "l1_batch": true,
      "l2a_rewrite": true,
      "l2b_validation": true,
      "human_review_sample_rate": 0.05
    }
  },
  "data": {
    "backend": [
      "cudf",
      "duckdb",
      "pandas"
    ],
    "format": "parquet",
    "train_split": 0.7,
    "val_split": 0.15,
    "preprocessing": {
      "fit_subsample_limit": 10000,
      "income": {
        "null_indicator": 0,
        "null_rate": 0.254,
        "strategy": "median"
      },
      "tenure_months": {
        "sentinel": -999999,
        "strategy": "clip_and_flag",
        "clip_min": 0,
        "clip_max": 256,
        "flag_col": "tenure_unknown"
      },
      "leakage_prevention": {
        "recompute_prod_from_seq": true,
        "validate_after_split": true
      }
    },
    "source": "data/benchmark/benchmark_v2.parquet",
    "s3_path": "s3://YOUR_S3_BUCKET/data/santander/",
    "id_col": "customer_id",
    "total_rows": 941132,
    "temporal_split": {
      "enabled": true,
      "date_col": "snapshot_date",
      "gap_days": 30,
      "train_ratio": 0.7,
      "val_ratio": 0.15
    },
    "split_strategy": {
      "state_tasks": {
        "tasks": [
          "churn_signal",
          "product_stability",
          "segment_prediction"
        ],
        "val_method": "random"
      },
      "future_tasks": {
        "tasks": [
          "nba_primary",
          "will_acquire_deposits",
          "will_acquire_investments",
          "will_acquire_accounts",
          "will_acquire_lending",
          "will_acquire_payments",
          "cross_sell_count"
        ],
        "val_method": "temporal_latest"
      },
      "sequence_tasks": {
        "tasks": [
          "next_mcc",
          "mcc_diversity_trend",
          "top_mcc_shift"
        ],
        "val_method": "temporal_latest"
      }
    }
  },
  "features": {
    "input_dim": 512,
    "id_cols": [
      "customer_id"
    ],
    "meta_cols": [
      "snapshot_date"
    ],
    "categorical": [
      {
        "name": "gender",
        "cardinality": 2,
        "embedding_dim": 4
      },
      {
        "name": "segment",
        "cardinality": 4,
        "embedding_dim": 4
      },
      {
        "name": "country",
        "cardinality": 118,
        "embedding_dim": 16
      },
      {
        "name": "channel",
        "cardinality": 163,
        "embedding_dim": 16
      },
      {
        "name": "age_group",
        "cardinality": 5,
        "embedding_dim": 4
      },
      {
        "name": "income_group",
        "cardinality": 5,
        "embedding_dim": 4
      }
    ],
    "numeric": [
      "age",
      "income",
      "tenure_months",
      "is_active",
      "num_products"
    ]
  },
  "aws": {
    "region": "ap-northeast-2",
    "s3_bucket": "aiops-ple-financial",
    "instance_type": "ml.g4dn.xlarge",
    "cpu_instance_type": "ml.m5.2xlarge",
    "use_spot": true,
    "max_run_seconds": 43200,
    "role_arn": "arn:aws:iam::795833413857:role/AWSPLEPlatformSageMakerRole"
  },
  "rule_engine": {
    "enabled": true,
    "suitability_check": true,
    "product_adjacency": {
      "path": [
        "deposits",
        "savings",
        "investment",
        "insurance",
        "lending"
      ]
    },
    "dormancy_thresholds": {
      "warning_days": 30,
      "alert_days": 60,
      "dormant_days": 90
    },
    "clv_tiers": {
      "premium_percentile": 80,
      "target_products": {
        "premium": 4,
        "stable": 3,
        "growth": 2,
        "at_risk": 1
      }
    },
    "rfm_thresholds": {
      "recency_warning_days": 30,
